		yr_addtn += (AddC1 / rcnrvl + AddC2 / rcnrl + AddC3 / rcnrr);

		AddC1 = 0.0;
		AddC2 = 0.0;
		AddC3 = 0.0;
		AddP = 0.0;

		//root litter incorporation
		AddCN = rootcn[ccwc];
