			//	AddP = CropP[ccwc] * 0.01 /0.4 * sRoot * 0.1 / (float)(q - 6);
			}

			alloc_litter_into_pools(&AddCN, &AddC, 10, &AddC1, &AddC2, &AddC3, &dInertC, 0, rcnrvl, rcnrl, rcnrr, nh4);
			rcvl[l] += AddC1;
